PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/projex_db?retryWrites=true&w=majority&appName=Cluster0

# Firebase Admin SDK — path to your downloaded service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json
# OR paste the JSON inline (useful for cloud deployments):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Frontend URL for CORS
CLIENT_URL=http://localhost:3000

NODE_ENV=development
